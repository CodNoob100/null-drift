FROM rust:1.95 AS builder
WORKDIR /app
COPY . .
# Build the gateway
RUN cargo build --release --bin gateway-rs

FROM debian:bookworm-slim
# Install runtime dependencies for reqwest and ONNX runtime
RUN apt-get update && apt-get install -y ca-certificates libssl-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /app/target/release/gateway-rs .
ENV HOST=0.0.0.0
ENV PORT=8000
EXPOSE 8000
CMD ["./gateway-rs"]
